"NSAppleMusicUsageDescription" = "Primuse needs access to your Apple Music / iTunes library to import its local tracks as a playback source.";
"NSLocalNetworkUsageDescription" = "Primuse needs local network access to discover and connect to your NAS devices, media servers, and other music sources.";
